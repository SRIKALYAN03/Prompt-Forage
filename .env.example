# PromptForge environment variables
# Copy this file to .env and fill in your values:
#   copy .env.example .env

# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=PromptForge
DEBUG=false
HOST=0.0.0.0
PORT=8000

# ── LLM Providers ────────────────────────────────────────────────────────────
# Anthropic (Claude) — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# OpenAI (GPT) — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Ollama (local — no API key required)
# Local run:  http://localhost:11434
# Docker:     http://ollama:11434          (with docker compose --profile ollama)
# Docker host: http://host.docker.internal:11434  (Ollama on your machine)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.2

# Custom OpenAI-compatible endpoint (vLLM, LM Studio, Together AI, etc.)
CUSTOM_ENDPOINT_URL=
CUSTOM_ENDPOINT_KEY=
CUSTOM_ENDPOINT_MODEL=

# ── Guardrails ───────────────────────────────────────────────────────────────
DEFAULT_TOKEN_LIMIT=4000
ENABLE_PII_SCAN=true
ENABLE_INJECTION_GUARD=true
ENABLE_HALLUCINATION_GUARD=true

# ── Storage ──────────────────────────────────────────────────────────────────
LOCAL_STORAGE_PATH=./prompts

# GitHub Gist export — https://github.com/settings/tokens
GITHUB_TOKEN=
